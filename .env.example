# ── Chat model (any OpenAI-compatible endpoint) ──────────────────────
# For remote providers (OpenAI, Azure, Together, etc.):
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-5-mini
# For local servers (vLLM, Ollama, NIM, LM Studio, etc.):
#   LLM_API_KEY=            # leave empty — "not-needed" is used automatically
#   LLM_BASE_URL=http://localhost:8000/v1
#   LLM_MODEL=meta/llama-3.1-8b-instruct
# For DGX Spark (see docker-compose-spark.yml — env is set in the overlay):
#   LLM_MODEL=gpt-oss-120b        # or gpt-oss-20b for lighter setup
#   EMBEDDING_MODEL=Qwen3-Embedding-4B
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Optional: set temperature (reasoning models like gpt-5-mini reject this)
# LLM_TEMPERATURE=0.7

# ── Embeddings (any OpenAI-compatible /v1/embeddings endpoint) ───────
# Falls back to LLM_API_KEY / LLM_BASE_URL if left empty.
# For local embeddings (e.g. TEI, vLLM, NIM, llama.cpp --embeddings):
#   EMBEDDING_BASE_URL=http://localhost:9000/v1
#   EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

MAX_TURNS=12

# Retrieval tuning (optional)
RAG_RETRIEVAL_K=14
RAG_MAX_SNIPPETS_PER_SOURCE=4
# RAG_MIN_CHUNK_CHARS=120
